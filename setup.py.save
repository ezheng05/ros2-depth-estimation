from setuptools import find_packages, setup

package_name = 'depth_estimation_pkg'

setup(
    name=package_name,
    version='0.1.0',
    packages=find_packages(exclude=['test']),
    data_files=[
        ('share/ament_index/resource_index/packages',
            ['resource/' + package_name]),
        ('share/' + package_name, ['package.xml']),
    ],
    install_requires=['setuptools'],
    zip_safe=True,
    maintainer='ellen',
    maintainer_email='ellen@example.com',
    description='Simple depth estimation with obstacle warning',
    license='MIT',
    tests_require=['pytest'],
    entry_points={
        'console_scripts': [
            # Core nodes (simplified)
            'limo_camera_bridge = depth_estimation_pkg.limo_camera_bridge:main',
            'depth_obstacle_node = depth_estimation_pkg.depth_obstacle_node:main',
            'keyboard_warning_node = depth_estimation_pkg.keyboard_warning_node:main',
            
            # Keep old nodes if you still need them
            'camera_node = depth_estimation_pkg.camera_node:main',
            'depth_estimation_node = depth_estimation_pkg.depth_estimation_node:main',
            
		'near_node = depth_estimation_pkg.near_node:main',
        ],
    },
)
